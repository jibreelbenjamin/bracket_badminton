# Supabase Project URL (dari Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co

# Supabase Service Role Key (⚠️ BUKAN anon key — dari Project Settings → API)
SUPABASE_SERVICE_ROLE_KEY=isi-dengan-service-role-key-anda

# Secret untuk menandatangani cookie sesi PIN (HMAC-SHA256)
# Buat dengan: openssl rand -hex 32
APP_SESSION_SECRET=isi-dengan-string-acak-panjang
